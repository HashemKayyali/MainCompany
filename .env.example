# Supabase project credentials (required)
# Get these from your Supabase project dashboard: Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Social login is handled entirely through Supabase Auth.
# You do NOT need frontend OAuth client secrets here.
# Configure providers in Supabase Dashboard: Authentication > Providers
#
# Required provider dashboard setup:
# - Google:   https://supabase.com/docs/guides/auth/social-login/auth-google
# - Facebook: https://supabase.com/docs/guides/auth/social-login/auth-facebook
# - Apple:    https://supabase.com/docs/guides/auth/social-login/auth-apple
#
# Authorized redirect URI for all providers:
#   https://www.eventiesjo.com/auth/callback
#   http://localhost:5173/auth/callback
